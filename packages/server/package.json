{
  "name": "@orc-brain/server",
  "version": "1.0.0",
  "description": "Fastify REST + SSE server for orc-brain, serving the API and the web UI.",
  "type": "module",
  "license": "MIT",
  "author": "Paulo Lima",
  "homepage": "https://github.com/anplabs/orc-brain#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anplabs/orc-brain.git",
    "directory": "packages/server"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@orc-brain/core": "workspace:*",
    "@orc-brain/shared": "workspace:*",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2"
  }
}
