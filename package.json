{
  "name": "orc-brain",
  "version": "1.0.0",
  "description": "Local orchestrator brain for Claude Code sub-agents.",
  "private": true,
  "type": "module",
  "license": "ISC",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "dev": "pnpm -r --parallel dev"
